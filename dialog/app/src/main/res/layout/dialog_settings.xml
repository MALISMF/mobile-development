<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_language"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/radio_language"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">
        <RadioButton
            android:id="@+id/lang_ru"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lang_ru"/>
        <RadioButton
            android:id="@+id/lang_en"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lang_en"/>
    </RadioGroup>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_design"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/radio_design"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">
        <RadioButton
            android:id="@+id/design_brief"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_brief"/>
        <RadioButton
            android:id="@+id/design_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_detail"/>
    </RadioGroup>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_city"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/radio_city"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <RadioButton
            android:id="@+id/city_moscow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/city_moscow"/>
        <RadioButton
            android:id="@+id/city_london"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/city_london"/>
        <RadioButton
            android:id="@+id/city_berlin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/city_berlin"/>
    </RadioGroup>
</LinearLayout>
